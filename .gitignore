# ==============================================================================
#                      Python & Package Management
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
eggs/

# Installer logs & reports
pip-log.txt
.coverage
.cache
htmlcov/


# ==============================================================================
#                      Virtual Environments
# ==============================================================================
# Ignore all common virtual environment folders.
.env
.venv
env/
venv/
ENV/


# ==============================================================================
#                      Django Specific
# ==============================================================================
# Local database file for SQLite (we don't use it, but good practice to ignore).
db.sqlite3
db.sqlite3-journal

# Log files.
*.log

# Project-specific folders generated by Django or our configuration.
# The leading '/' ensures we only ignore these folders at the project root.
/backend/staticfiles/
/backend/mediafiles/
/logs/

# ==============================================================================
#                      Docker Specific
# ==============================================================================
# Ignore the persistent data volume for our PostgreSQL database.
/postgres_data/


# ==============================================================================
#                      OS & Editor Specific
# ==============================================================================

# macOS
.DS_Store

# VS Code
.vscode/
settings.json